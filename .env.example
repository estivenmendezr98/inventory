# ============================================
# SISTEMA DE INVENTARIO — Variables de Entorno
# ============================================
# Copiar este archivo como .env y ajustar valores

# --- PostgreSQL App (inventory_bd) ---
DB_APP_NAME=inventory_bd
DB_APP_USER=root
DB_APP_PASSWORD=1234
DB_APP_HOST=postgres-app
DB_APP_PORT=5432
DATABASE_URL=postgresql://root:1234@postgres-app:5432/inventory_bd?schema=public

# --- PostgreSQL Keycloak (keycloak_bd) ---
DB_KC_NAME=keycloak_bd
DB_KC_USER=keycloak_user
DB_KC_PASSWORD=kc_secure_2024
DB_KC_HOST=postgres-keycloak
DB_KC_PORT=5432

# --- Keycloak ---
# Consola master (gestión): KEYCLOAK_ADMIN / KEYCLOAK_ADMIN_PASSWORD del servicio keycloak (por defecto admin/admin).
# App (realm inventory): usuario "superadmin" o correo admin@inventory.local, contraseña admin123 (realm-export.json).
# Si el backend corre en Docker y el token falla: KC_PUBLIC_URL debe ser la URL con la que el navegador abre Keycloak (p. ej. http://localhost:8080).
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=admin
KC_REALM=inventory
KC_CLIENT_ID=inventory-app
KC_BASE_URL=http://keycloak:8080
KC_PUBLIC_URL=http://localhost:8080
# Realm del usuario administrador de Keycloak para la API Admin (password grant). Casi siempre master.
KC_ADMIN_REALM=master
# Secreto compartido para POST /api/auth/keycloak/webhook (cabecera X-Inventory-Webhook-Secret).
# Vacío = webhook deshabilitado (503). En producción use un valor largo y aleatorio.
KEYCLOAK_WEBHOOK_SECRET=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=inventory-documents
# true solo si MinIO expone HTTPS
MINIO_USE_SSL=false

# --- Backend ---
NODE_ENV=development
BACKEND_PORT=3000
JWT_SECRET=dev-jwt-secret-change-in-production
CORS_ORIGIN=http://localhost
# Directorio donde Nest guarda los .sql de pg_dump (relativo al cwd del backend o ruta absoluta)
BACKUP_STORAGE_PATH=storage/backups
# Facturas PDF/XML (Fase 1: disco local + opcional espejo en MinIO)
INVOICE_STORAGE_PATH=storage/invoices
# Solo desarrollo: fuerza regeneración de PDF/XML aunque ya existan (p. ej. tras cambiar maquetación). En producción suele ser false.
# INVOICE_FORCE_REGENERATE_ARTIFACTS=true
# --- Facturación electrónica (Colombia / DIAN) — CUFE + UBL 2.1 + QR catálogo ---
# NIT del obligado a facturar (solo dígitos). En producción use el NIT real.
ELECTRONIC_INVOICING_SUPPLIER_NIT=900000000
# Opcional: dígito de verificación si lo informa aparte en representación gráfica
# ELECTRONIC_INVOICING_SUPPLIER_DV=
ELECTRONIC_INVOICING_SUPPLIER_NAME=Mi empresa S.A.S.
ELECTRONIC_INVOICING_SUPPLIER_CITY=Bogotá D.C.
ELECTRONIC_INVOICING_SUPPLIER_ADDRESS=Calle 1 # 2-3
# Clave técnica del software registrado en la DIAN (concatenación CUFE). Sustituya el placeholder.
ELECTRONIC_INVOICING_TECHNICAL_KEY=CLAVE_TECNICA_PLACEHOLDER_REEMPLACE_CON_REGISTRO_DIAN_012345678901234567890123456789012345678901234567890
# PIN del software (reservado para representación gráfica / integraciones PT)
ELECTRONIC_INVOICING_SOFTWARE_PIN=12345
# 2 = habilitación / pruebas (URL QR catálogo habilitación). 1 = producción.
ELECTRONIC_INVOICING_ENVIRONMENT=2
# Proveedor tecnológico (HTTP): si DIAN_PROVIDER_MODE=http y DIAN_HTTP_API_BASE está definida, el backend delega en esas rutas.
# Rutas esperadas bajo la base: POST /send-invoice, GET /invoice-status?trackId=, POST /validate-document, POST /send-credit-note
DIAN_PROVIDER_MODE=internal
# DIAN_HTTP_API_BASE=https://mi-pt-interno.example.com/api/fel
# DIAN_HTTP_BEARER_TOKEN=
# DIAN_HTTP_TIMEOUT_MS=20000
# Opcional: ruta completa a pg_dump.exe en Windows si no está en el PATH (también se busca bajo Program Files)
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\17\bin\pg_dump.exe

# --- Frontend ---
# Con Vite en desarrollo (npm run dev en :5173): usa «/api» para que el proxy reenvíe a Nest (vite.config → VITE_DEV_PROXY_TARGET).
# Con build detrás de Nginx en :80: usa http://localhost/api
VITE_API_URL=/api
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
VITE_KC_URL=http://localhost:8080
VITE_KC_REALM=inventory
VITE_KC_CLIENT_ID=inventory-app

# --- Netdata ---
NETDATA_PORT=19999
# URL del panel Netdata en el navegador (frontend: enlace «Abrir Netdata» en /monitoring)
VITE_NETDATA_URL=http://localhost:19999

# --- Playwright E2E (raíz del monorepo: npm run test:e2e / test:e2e:sales) ---
# E2E_BASE_URL=http://localhost:5173
# E2E_REUSE_VITE=1
# E2E_KC_USERNAME=superadmin
# E2E_KC_PASSWORD=admin123
# Opcional: segundo usuario con rol CAJERO en Keycloak (activa el segundo test en tests/sales-ui-5173.spec.ts)
# E2E_KC_CAJERO_USERNAME=cajero
# E2E_KC_CAJERO_PASSWORD=...
