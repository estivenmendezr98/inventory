// ============================================
// Prisma Schema — Sistema de Inventario
// Base de datos: inventory_bd (PostgreSQL 17)
// ============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum RoleName {
  SUPER_ADMINISTRADOR
  ADMINISTRADOR
  CAJERO
}

enum KardexType {
  IN
  OUT
  ADJUST
}

/// Agrupa unidades (metro/litro/gramo vs pieza/caja).
enum UnitCategory {
  COUNT
  LENGTH
  VOLUME
  WEIGHT
  AREA
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  PENDING
  COMPLETED
  SUSPENDED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
}

enum CashMovementType {
  INCOME
  EXPENSE
  SALE
}

enum SaleAdjustmentAction {
  ADD
  REMOVE
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum InvoiceStatus {
  ACTIVE
  ACTIVE_ADJUSTED
  CANCELLED
  VOIDED
}

enum DocumentType {
  CC
  NIT
  CE
  TI
  PASSPORT
  OTHER
}

// ============================================
// RBAC — Roles, Permisos, Usuarios
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id          String    @id @default(uuid())
  keycloakId  String?   @unique
  email       String    @unique
  firstName   String
  lastName    String
  phone       String?
  avatar      String?
  roleId      String
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  role          Role           @relation(fields: [roleId], references: [id])
  sessions      UserSession[]
  audits        AuditLog[]
  sales              Sale[]
  saleAdjustments    SaleAdjustment[]
  purchases     Purchase[]
  cashSessions  CashSession[]
  cashMovements CashMovement[]
  kardexEntries KardexEntry[]
  adjustments   InventoryAdjustment[]
  documents     Document[]
  notifications Notification[]

  @@map("users")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  module     String
  entityId   String?
  entityType String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([module, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

// ============================================
// CONFIGURACIÓN GENERAL
// ============================================

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ============================================
// PRODUCTOS Y CATEGORÍAS
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model UnitOfMeasure {
  id             String       @id @default(uuid())
  code           String       @unique
  name           String
  symbol         String
  category       UnitCategory
  allowsDecimals Boolean      @default(false)
  decimalPlaces  Int          @default(0)
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  productsInventory   Product[]              @relation("ProductInventoryUnit")
  productsContent     Product[]              @relation("ProductContentUnit")
  productAlternates   ProductAlternateUnit[]
  saleItems           SaleItem[]
  purchaseItems       PurchaseItem[]         @relation("PurchaseItemUnit")
  kardexOperational   KardexEntry[]          @relation("KardexOperationalUnit")

  @@map("units_of_measure")
}

/// Unidad de venta/compra distinta a la base: 1 unidad alterna = factorToBase unidades base.
model ProductAlternateUnit {
  id              String   @id @default(uuid())
  productId       String
  unitOfMeasureId String
  factorToBase    Decimal  @db.Decimal(14, 6)
  label           String?  @db.VarChar(64)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitOfMeasure UnitOfMeasure @relation(fields: [unitOfMeasureId], references: [id])

  @@unique([productId, unitOfMeasureId])
  @@map("product_alternate_units")
}

model Product {
  id              String   @id @default(uuid())
  sku             String   @unique
  barcode         String?  @unique
  name            String
  description     String?
  categoryId      String?
  /// Unidad base obligatoria: todo el stock y mínimos se expresan en esta unidad.
  unitOfMeasureId String
  /// Texto libre: presentación o tamaño (ej. botella 500 mL, rollo 100 m).
  measureDetail   String?  @db.VarChar(255)
  /// @deprecated Usar `alternateUnits`. Cantidad de contentUnit por unidad base.
  contentPerUnit  Decimal? @db.Decimal(14, 4)
  /// @deprecated Usar `alternateUnits`.
  contentUnitId   String?
  costPrice       Decimal  @db.Decimal(12, 2)
  salePrice       Decimal  @db.Decimal(12, 2)
  taxRate         Decimal  @default(0) @db.Decimal(5, 2)
  minStock        Decimal  @default(0) @db.Decimal(14, 4)
  maxStock        Decimal  @default(0) @db.Decimal(14, 4)
  imageUrl        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        Category?      @relation(fields: [categoryId], references: [id])
  unitOfMeasure   UnitOfMeasure  @relation("ProductInventoryUnit", fields: [unitOfMeasureId], references: [id])
  contentUnit     UnitOfMeasure?         @relation("ProductContentUnit", fields: [contentUnitId], references: [id])
  alternateUnits  ProductAlternateUnit[]
  inventory       Inventory[]
  kardexEntries KardexEntry[]
  adjustments   InventoryAdjustment[]
  saleItems            SaleItem[]
  saleAdjustmentLines  SaleAdjustmentLine[]
  purchaseItems PurchaseItem[]

  @@map("products")
}

// ============================================
// INVENTARIO Y KARDEX
// ============================================

model Inventory {
  id          String  @id @default(uuid())
  productId   String
  quantity    Decimal @default(0) @db.Decimal(14, 4)
  reservedQty Decimal @default(0) @db.Decimal(14, 4)

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId])
  @@map("inventory")
}

model KardexEntry {
  id            String    @id @default(uuid())
  productId     String
  type          KardexType
  /// Movimiento en unidad base del producto (con signo).
  quantity      Decimal @db.Decimal(14, 4)
  previousStock Decimal @db.Decimal(14, 4)
  newStock      Decimal @db.Decimal(14, 4)
  /// Cantidad en unidad operativa (compra/venta), si aplica.
  operationalQuantity Decimal? @db.Decimal(14, 4)
  operationalUnitId   String?
  /// factorToBase usado: |quantity| = |operationalQuantity| * conversionFactor
  conversionFactor    Decimal? @db.Decimal(14, 6)
  unitCost      Decimal   @db.Decimal(12, 2)
  totalCost     Decimal   @db.Decimal(12, 2)
  referenceType String?
  referenceId   String?
  notes         String?
  userId        String
  createdAt     DateTime  @default(now())

  product           Product        @relation(fields: [productId], references: [id])
  user              User           @relation(fields: [userId], references: [id])
  operationalUnit   UnitOfMeasure? @relation("KardexOperationalUnit", fields: [operationalUnitId], references: [id])

  @@index([productId, createdAt])
  @@map("kardex_entries")
}

model InventoryAdjustment {
  id          String   @id @default(uuid())
  productId   String
  type        String
  previousQty Decimal @db.Decimal(14, 4)
  newQty      Decimal @db.Decimal(14, 4)
  reason      String
  userId      String
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("inventory_adjustments")
}

// ============================================
// PROVEEDORES Y COMPRAS
// ============================================

model Supplier {
  id          String   @id @default(uuid())
  nit         String   @unique
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases Purchase[]

  @@map("suppliers")
}

model Purchase {
  id         String         @id @default(uuid())
  supplierId String
  number     String         @unique
  date       DateTime
  subtotal   Decimal        @db.Decimal(12, 2)
  taxTotal   Decimal        @db.Decimal(12, 2)
  total      Decimal        @db.Decimal(12, 2)
  status     PurchaseStatus @default(DRAFT)
  notes      String?
  userId     String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  user     User           @relation(fields: [userId], references: [id])
  items    PurchaseItem[]

  @@map("purchases")
}

model PurchaseItem {
  id           String  @id @default(uuid())
  purchaseId   String
  productId    String
  /// Cantidad en unidad de compra elegida.
  quantity     Decimal @db.Decimal(14, 4)
  /// Cantidad sumada al inventario (unidad base).
  baseQuantity Decimal @db.Decimal(14, 4)
  purchaseUnitId String?
  unitCost     Decimal @db.Decimal(12, 2)
  taxRate      Decimal @db.Decimal(5, 2)
  subtotal     Decimal @db.Decimal(12, 2)

  purchase     Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id])
  purchaseUnit UnitOfMeasure? @relation("PurchaseItemUnit", fields: [purchaseUnitId], references: [id])

  @@map("purchase_items")
}

// ============================================
// CLIENTES
// ============================================

model Customer {
  id             String       @id @default(uuid())
  documentType   DocumentType @default(CC)
  documentNumber String       @unique
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  sales Sale[]

  @@map("customers")
}

// ============================================
// VENTAS Y POS
// ============================================

model Sale {
  id             String     @id @default(uuid())
  number         String     @unique
  customerId     String?
  userId         String
  cashSessionId  String?
  subtotal       Decimal    @db.Decimal(12, 2)
  discountTotal  Decimal    @default(0) @db.Decimal(12, 2)
  taxTotal       Decimal    @db.Decimal(12, 2)
  total          Decimal    @db.Decimal(12, 2)
  status         SaleStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customer    Customer?    @relation(fields: [customerId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  items       SaleItem[]
  payments    Payment[]
  invoice     Invoice?
  adjustments SaleAdjustment[]

  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id           String   @id @default(uuid())
  saleId       String
  productId    String
  /// Cantidad en la unidad de venta elegida (ej. 45 cm o 2 tubos).
  quantity     Decimal  @db.Decimal(14, 4)
  /// Cantidad descontada del inventario (unidad base del producto).
  baseQuantity Decimal  @db.Decimal(14, 4)
  saleUnitId   String?
  unitPrice    Decimal  @db.Decimal(12, 2)
  discount     Decimal  @default(0) @db.Decimal(12, 2)
  taxRate      Decimal  @db.Decimal(5, 2)
  subtotal     Decimal  @db.Decimal(12, 2)

  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
  saleUnit  UnitOfMeasure? @relation(fields: [saleUnitId], references: [id])

  @@map("sale_items")
}

model Payment {
  id        String        @id @default(uuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  change    Decimal       @default(0) @db.Decimal(12, 2)
  createdAt DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model SaleAdjustment {
  id            String   @id @default(uuid())
  saleId        String
  cashSessionId String?
  reason        String
  totalBefore   Decimal  @db.Decimal(12, 2)
  totalAfter    Decimal  @db.Decimal(12, 2)
  cashDelta     Decimal  @default(0) @db.Decimal(12, 2)
  createdById   String
  createdAt     DateTime @default(now())

  sale        Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  cashSession CashSession?       @relation(fields: [cashSessionId], references: [id])
  createdBy   User               @relation(fields: [createdById], references: [id])
  lines       SaleAdjustmentLine[]

  @@index([saleId])
  @@map("sale_adjustments")
}

model SaleAdjustmentLine {
  id           String               @id @default(uuid())
  adjustmentId String
  action       SaleAdjustmentAction
  productId    String
  saleItemId   String?
  quantity     Decimal              @db.Decimal(14, 4)
  unitPrice    Decimal?             @db.Decimal(12, 2)
  lineSubtotal Decimal?             @db.Decimal(12, 2)

  adjustment SaleAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product    Product        @relation(fields: [productId], references: [id])

  @@map("sale_adjustment_lines")
}

// ============================================
// FACTURACIÓN
// ============================================

model Invoice {
  id               String        @id @default(uuid())
  saleId           String        @unique
  number           Int
  prefix           String
  resolutionNumber String
  date             DateTime
  subtotal         Decimal       @db.Decimal(12, 2)
  taxTotal         Decimal       @db.Decimal(12, 2)
  total            Decimal       @db.Decimal(12, 2)
  status           InvoiceStatus @default(ACTIVE)
  customerName     String?
  customerDoc      String?
  /// TrackId del proveedor (stub local o PT); preparado para consulta de estado DIAN.
  electronicTrackId String?
  /// CUFE SHA-384 (hex mayúsculas). Requiere datos de emisor y clave técnica configurados.
  cufe             String?
  /// URL del código QR (catálogo DIAN). Vacío si no hubo CUFE.
  qrPayload        String?
  pdfUrl           String?
  xmlUrl           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  sale Sale @relation(fields: [saleId], references: [id])

  @@unique([prefix, number])
  @@map("invoices")
}

model InvoiceNumbering {
  id               String   @id @default(uuid())
  prefix           String   @unique
  resolutionNumber String
  startNumber      Int
  endNumber        Int
  currentNumber    Int
  startDate        DateTime
  endDate          DateTime
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("invoice_numbering")
}

// ============================================
// CAJA
// ============================================

model CashRegister {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions CashSession[]

  @@map("cash_registers")
}

model CashSession {
  id             String            @id @default(uuid())
  cashRegisterId String
  userId         String
  openingAmount  Decimal           @db.Decimal(12, 2)
  closingAmount  Decimal?          @db.Decimal(12, 2)
  expectedAmount Decimal?          @db.Decimal(12, 2)
  difference     Decimal?          @db.Decimal(12, 2)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?
  status         CashSessionStatus @default(OPEN)

  cashRegister CashRegister   @relation(fields: [cashRegisterId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  sales           Sale[]
  movements       CashMovement[]
  saleAdjustments SaleAdjustment[]

  @@map("cash_sessions")
}

model CashMovement {
  id          String           @id @default(uuid())
  sessionId   String
  type        CashMovementType
  amount      Decimal          @db.Decimal(12, 2)
  description String?
  userId      String
  createdAt   DateTime         @default(now())

  session CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@map("cash_movements")
}

// ============================================
// CONFIGURACIÓN
// ============================================

model CompanySettings {
  id            String  @id @default(uuid())
  name          String
  nit           String
  address       String?
  city          String?
  phone         String?
  email         String?
  logo          String?
  taxRegime     String?
  invoiceFooter String?

  @@map("company_settings")
}

model SystemSettings {
  id       String @id @default(uuid())
  key      String @unique
  value    String
  type     String @default("string")
  category String @default("general")

  @@map("system_settings")
}

// ============================================
// DOCUMENTOS Y NOTIFICACIONES
// ============================================

model Document {
  id         String   @id @default(uuid())
  name       String
  type       String
  path       String
  size       Int
  mimeType   String
  module     String
  entityId   String?
  uploadedBy String
  createdAt  DateTime @default(now())

  user User @relation(fields: [uploadedBy], references: [id])

  @@map("documents")
}

model Notification {
  id       String   @id @default(uuid())
  userId   String
  title    String
  message  String
  type     String   @default("info")
  isRead   Boolean  @default(false)
  module   String?
  entityId String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
