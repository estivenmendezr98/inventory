# Backend local .env (for running Prisma CLI outside Docker)
DATABASE_URL=postgresql://root:1234@localhost:5432/inventory_bd?schema=public
NODE_ENV=development
PORT=3000
KC_BASE_URL=http://localhost:8080
# Debe coincidir con el `iss` del JWT del navegador si difiere de KC_BASE_URL (p. ej. Docker → público).
KC_PUBLIC_URL=http://localhost:8080
KC_REALM=inventory
KC_CLIENT_ID=inventory-app
REDIS_HOST=localhost
REDIS_PORT=6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=inventory-documents
